# === AI Browser Agent Environment Variables ===
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# Gemini API Key (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# SerpAPI Key (https://serpapi.com/dashboard)
SERPAPI_API_KEY=your_serpapi_api_key_here

# AES-256 Encryption Secret (must be exactly 32 characters)
ENCRYPTION_SECRET=your_32_character_secret_key_here

# PostgreSQL
DB_HOST=localhost
DB_PORT=5433
DB_NAME=browserai
DB_USERNAME=browserai
DB_PASSWORD=your_db_password_here

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# File Storage Path
STORAGE_PATH=./storage
